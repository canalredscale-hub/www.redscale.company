#!/bin/sh
set -eu

blocked_paths='^frontend/|(^|/)(backups|test-results)/|(^|/)\.codex-.*\.png$|(^|/)\.hero-update-shot.*\.png$|INFORITUWKS210|(^|/)\.env(\.|$)|\.(key|pem|p12|pfx|kdbx|sqlite3?|db|sql|dump|bak)$|secret|credential|token'
allowed_frontend_assets='^app/frontend/assets/'

staged_files="$(git diff --cached --name-only --diff-filter=ACMRT)"

blocked_asset_hits="$(printf '%s\n' "$staged_files" | grep -Ei '(^|/)assets/' | grep -Eiv "$allowed_frontend_assets" || true)"
blocked_other_hits="$(printf '%s\n' "$staged_files" | grep -Ei "$blocked_paths" || true)"
blocked_hits="$(printf '%s\n%s\n' "$blocked_asset_hits" "$blocked_other_hits" | sed '/^$/d')"

if [ -n "$blocked_hits" ]; then
  echo "Commit bloqueado: ha arquivos proibidos ou sensiveis no stage." >&2
  echo "$blocked_hits" >&2
  exit 1
fi

scan_files="$(git diff --cached --name-only --diff-filter=ACM | grep -Ev '^(\.githooks/|\.gitignore$|\.gitattributes$)' || true)"
secret_hits=""

if [ -n "$scan_files" ]; then
  secret_hits="$(printf '%s\n' "$scan_files" | xargs -r git grep --cached -I -n -E '(api[_-]?key|client[_-]?secret|private[_-]?key|password|credential|BEGIN (RSA |OPENSSH |EC |DSA )?PRIVATE KEY|senha[[:space:]]*[:=])' -- 2>/dev/null || true)"
fi

if [ -n "$secret_hits" ]; then
  echo "Commit bloqueado: possiveis segredos encontrados no conteudo staged." >&2
  echo "$secret_hits" >&2
  exit 1
fi
